generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum StatType {
  FORCE
  INTELLIGENCE
  DEXTERITE
  AGILITE
  VIE
  CHANCE
  PA
  PM
  PO
  CRITIQUE
  DOMMAGES
  SOINS
}

enum ZoneType {
  CASE
  CROIX
  LIGNE
  CONE
  CERCLE
  LIGNE_PERPENDICULAIRE
  DIAGONALE
  CARRE
  ANNEAU
  CONE_INVERSE
}

enum SortType {
  ARME
  SORT
}

enum SlotType {
  ARME
  COIFFE
  AMULETTE
  BOUCLIER
  HAUT
  BAS
  ANNEAU1
  ANNEAU2
  FAMILIER
}

enum EffetType {
  BUFF
  DEBUFF
  DISPEL
  POUSSEE
  ATTIRANCE
  POISON
  BOUCLIER
  RESISTANCE
}

enum CombatStatus {
  EN_COURS
  TERMINE
  ABANDONNE
}

enum RegionType {
  FORET
  PLAINE
  DESERT
  MONTAGNE
  MARAIS
  CAVERNE
  CITE
}

enum MapType {
  WILDERNESS
  VILLE
  DONJON
  BOSS
  SAFE
}

enum CombatMode {
  MANUEL
  AUTO
}

enum IAType {
  EQUILIBRE
  AGGRESSIF
  SOUTIEN
  DISTANCE
}

enum CombatLogType {
  ACTION
  DEPLACEMENT
  TOUR
  MORT
  EFFET
  EFFET_EXPIRE
  FIN
}

// ==================== TABLES STATIQUES ====================

model Race {
  id                Int          @id @default(autoincrement())
  nom               String       @unique
  bonusForce        Int          @default(0)
  bonusIntelligence Int          @default(0)
  bonusDexterite    Int          @default(0)
  bonusAgilite      Int          @default(0)
  bonusVie          Int          @default(0)
  bonusChance       Int          @default(0)
  personnages       Personnage[]
  sorts             Sort[]
}

model Zone {
  id          Int           @id @default(autoincrement())
  nom         String
  type        ZoneType
  taille      Int
  sorts       Sort[]
  equipements Equipement[]
}

model Sort {
  id                  Int              @id @default(autoincrement())
  nom                 String
  description         String?
  type                SortType
  statUtilisee        StatType
  coutPA              Int
  porteeMin           Int
  porteeMax           Int
  ligneDeVue          Boolean          @default(true)
  degatsMin           Int
  degatsMax           Int
  degatsCritMin       Int
  degatsCritMax       Int
  chanceCritBase      Float            @default(0.01)
  cooldown            Int              @default(0)
  estSoin             Boolean          @default(false)
  tauxEchec           Float            @default(0)
  niveauApprentissage Int              @default(1)
  zoneId              Int?
  zone                Zone?            @relation(fields: [zoneId], references: [id])
  raceId              Int?
  race                Race?            @relation(fields: [raceId], references: [id])
  estInvocation        Boolean          @default(false)
  estVolDeVie          Boolean          @default(false)
  invocationTemplateId Int?
  invocationTemplate   MonstreTemplate? @relation("InvocationSort", fields: [invocationTemplateId], references: [id])
  // Portée modifiable par équipement et buffs (false = portée fixe)
  porteeModifiable     Boolean          @default(true)
  // Ciblage en ligne droite uniquement (horizontal ou vertical)
  ligneDirecte         Boolean          @default(false)
  // Zones posées au sol
  estGlyphe            Boolean          @default(false)
  estPiege             Boolean          @default(false)
  poseDuree            Int?             // durée en tours de la zone posée (null = permanent)
  // Téléportation : déplace instantanément le lanceur vers la case ciblée (sans PM, ignore les obstacles de chemin)
  estTeleportation     Boolean          @default(false)
  // Self-buff : sort destiné uniquement à se booster soi-même (IA l'utilise sur soi au début du tour)
  estSelfBuff          Boolean          @default(false)
  // Coefficient multiplicateur appliqué aux dégâts/soins (utile pour réduire la puissance des sorts en zone)
  coefficient          Float            @default(1.0)
  personnages         PersonnageSort[]
  cooldowns           SortCooldown[]
  monstres            MonstreSort[]
  effets              SortEffet[]
}

model Equipement {
  id                Int       @id @default(autoincrement())
  nom               String
  slot              SlotType
  niveauMinimum     Int       @default(1)
  poids             Int       @default(1)
  bonusForce        Int       @default(0)
  bonusIntelligence Int       @default(0)
  bonusDexterite    Int       @default(0)
  bonusAgilite      Int       @default(0)
  bonusVie          Int       @default(0)
  bonusChance       Int       @default(0)
  bonusPA           Int       @default(0)
  bonusPM           Int       @default(0)
  bonusPO           Int       @default(0)
  // Ranges max pour stats aléatoires (null = stat fixe)
  bonusForceMax      Int?
  bonusIntelligenceMax Int?
  bonusDexteriteMax  Int?
  bonusAgiliteMax    Int?
  bonusVieMax        Int?
  bonusChanceMax     Int?
  bonusPAMax         Int?
  bonusPMMax         Int?
  bonusPOMax         Int?
  bonusCritiqueMax   Int?
  // Champs d'attaque (pour armes uniquement)
  degatsMin         Int?
  degatsMax         Int?
  chanceCritBase    Float?
  coutPA            Int?
  porteeMin         Int?
  porteeMax         Int?
  ligneDeVue        Boolean?
  zoneId            Int?
  zone              Zone?     @relation(fields: [zoneId], references: [id])
  statUtilisee      StatType?
  cooldown          Int?
  tauxEchec         Float?
  estVolDeVie       Boolean   @default(false)
  // Crit global pour armes multi-lignes
  bonusCrit         Int?
  bonusCritique     Int       @default(0)
  // Résistances aux dégâts (valeurs de base)
  resistanceForce          Int  @default(0)
  resistanceIntelligence   Int  @default(0)
  resistanceDexterite      Int  @default(0)
  resistanceAgilite        Int  @default(0)
  // Ranges max pour résistances aléatoires (null = résistance fixe)
  resistanceForceMax       Int?
  resistanceIntelligenceMax Int?
  resistanceDexteriteMax   Int?
  resistanceAgiliteMax     Int?
  // Bonus dommages et soins flat
  bonusDommages            Int  @default(0)
  bonusDommagesMax         Int?
  bonusSoins               Int  @default(0)
  bonusSoinsMax            Int?
  // Panoplie
  panoplieId        Int?
  panoplie          Panoplie? @relation(fields: [panoplieId], references: [id])
  lignesDegats      LigneDegatsArme[]
  inventaireItems   InventaireItem[]
  recettes          Recette[]
  drops             MonstreDrop[]
  marchandLignes    MarchandLigne[]
  queteRecompenses  QueteRecompense[]
  queteEtapes       QueteEtape[]          @relation("QueteEtapeEquipement")
}

model Effet {
  id           Int                @id @default(autoincrement())
  nom          String
  type         EffetType
  statCiblee   StatType
  valeur       Int
  valeurMin    Int?
  duree        Int
  // Si true: plusieurs instances du même effet peuvent coexister sur la même entité
  cumulable    Boolean            @default(false)
  sorts        SortEffet[]
  effetsActifs EffetActif[]
  zonesActives ZonePoseeCombat[]
}

model SortEffet {
  id                  Int     @id @default(autoincrement())
  sortId              Int
  sort                Sort    @relation(fields: [sortId], references: [id])
  effetId             Int
  effet               Effet   @relation(fields: [effetId], references: [id])
  chanceDeclenchement Float   @default(1.0)
  surCible            Boolean @default(true)

  @@unique([sortId, effetId])
}

model LigneDegatsArme {
  id              Int        @id @default(autoincrement())
  equipementId    Int
  equipement      Equipement @relation(fields: [equipementId], references: [id], onDelete: Cascade)
  ordre           Int        @default(1)
  degatsMin       Int
  degatsMax       Int
  statUtilisee    StatType
  estVolDeVie     Boolean    @default(false)
  estSoin         Boolean    @default(false)

  @@unique([equipementId, ordre])
  @@index([equipementId])
}

// ==================== MONDE & MAPS ====================

model Region {
  id          Int              @id @default(autoincrement())
  nom         String           @unique
  description String?
  type        RegionType
  niveauMin   Int              @default(1)
  niveauMax   Int              @default(10)
  maps        Map[]
  donjons     Donjon[]
  monstres    RegionMonstre[]
}

model Map {
  id              Int             @id @default(autoincrement())
  nom             String
  regionId        Int
  region          Region          @relation(fields: [regionId], references: [id])
  type            MapType
  combatMode      CombatMode
  largeur         Int             @default(16)
  hauteur         Int             @default(18)
  worldX          Int?
  worldY          Int?
  // Directional neighbors (self-referential)
  nordMapId       Int?
  nordMap         Map?            @relation("NordNeighbor", fields: [nordMapId], references: [id])
  nordOf          Map[]           @relation("NordNeighbor")
  sudMapId        Int?
  sudMap          Map?            @relation("SudNeighbor", fields: [sudMapId], references: [id])
  sudOf           Map[]           @relation("SudNeighbor")
  estMapId        Int?
  estMap          Map?            @relation("EstNeighbor", fields: [estMapId], references: [id])
  estOf           Map[]           @relation("EstNeighbor")
  ouestMapId      Int?
  ouestMap        Map?            @relation("OuestNeighbor", fields: [ouestMapId], references: [id])
  ouestOf         Map[]           @relation("OuestNeighbor")
  // Relations
  groupesEnnemis  GroupeEnnemi[]
  connectionsFrom MapConnection[] @relation("FromMap")
  connectionsTo   MapConnection[] @relation("ToMap")
  personnages     Personnage[]    @relation("PersonnageMap")
  donjonSalles    DonjonSalle[]
  cases           MapCase[]
  spawns          MapSpawn[]
  pnjs            PNJ[]
}

model MapConnection {
  id        Int     @id @default(autoincrement())
  fromMapId Int
  fromMap   Map     @relation("FromMap", fields: [fromMapId], references: [id])
  toMapId   Int?
  toMap     Map?    @relation("ToMap", fields: [toMapId], references: [id])
  positionX Int
  positionY Int
  nom       String
  donjonId  Int?
  donjon    Donjon? @relation(fields: [donjonId], references: [id])
}

model MonstreTemplate {
  id             Int                  @id @default(autoincrement())
  nom            String
  force          Int
  intelligence   Int
  dexterite      Int
  agilite        Int
  vie            Int
  chance         Int
  pvBase         Int
  paBase         Int                  @default(6)
  pmBase         Int                  @default(3)
  niveauBase     Int                  @default(1)
  xpRecompense   Int                  @default(10)
  iaType         IAType               @default(EQUILIBRE)
  pvScalingInvocation Float?
  orMin          Int                  @default(0)
  // Résistances de base (scalées par niveau au combat)
  resistanceForce          Int  @default(0)
  resistanceIntelligence   Int  @default(0)
  resistanceDexterite      Int  @default(0)
  resistanceAgilite        Int  @default(0)
  orMax          Int                  @default(0)
  groupesMembres    GroupeEnnemiMembre[]
  donjonsBoss       Donjon[]
  regions           RegionMonstre[]
  sorts             MonstreSort[]
  combatEntites     CombatEntite[]
  invocationSorts   Sort[]                   @relation("InvocationSort")
  drops             MonstreDrop[]
  salleCompositions DonjonSalleComposition[]
  queteEtapes       QueteEtape[]
}

model RegionMonstre {
  id          Int             @id @default(autoincrement())
  regionId    Int
  region      Region          @relation(fields: [regionId], references: [id])
  monstreId   Int
  monstre     MonstreTemplate @relation(fields: [monstreId], references: [id])
  probabilite Float           @default(1.0)

  @@unique([regionId, monstreId])
  @@index([regionId])
}

model MonstreSort {
  id        Int             @id @default(autoincrement())
  monstreId Int
  monstre   MonstreTemplate @relation(fields: [monstreId], references: [id])
  sortId    Int
  sort      Sort            @relation(fields: [sortId], references: [id])
  priorite  Int             @default(1)

  @@unique([monstreId, sortId])
  @@index([monstreId])
}

model GroupeEnnemi {
  id          Int                    @id @default(autoincrement())
  mapId       Int
  map         Map                    @relation(fields: [mapId], references: [id])
  positionX   Int
  positionY   Int
  vaincu      Boolean                @default(false)
  vainquuAt   DateTime?
  respawnTime Int?
  membres     GroupeEnnemiMembre[]

  @@index([mapId, vaincu])
}

model GroupeEnnemiMembre {
  id             Int             @id @default(autoincrement())
  groupeEnnemiId Int
  groupeEnnemi   GroupeEnnemi    @relation(fields: [groupeEnnemiId], references: [id], onDelete: Cascade)
  monstreId      Int
  monstre        MonstreTemplate @relation(fields: [monstreId], references: [id])
  quantite       Int             @default(1)
  niveau         Int             @default(1)

  @@index([groupeEnnemiId])
}

// ==================== TABLES DYNAMIQUES ====================

model Joueur {
  id          Int          @id @default(autoincrement())
  nom         String       @unique
  createdAt   DateTime     @default(now())
  personnages Personnage[]
  groupes     Groupe[]
}

model Personnage {
  id                     Int                @id @default(autoincrement())
  nom                    String
  niveau                 Int                @default(1)
  experience             Int                @default(0)
  pointsStatsDisponibles Int                @default(0)
  force                  Int
  intelligence           Int
  dexterite              Int
  agilite                Int
  vie                    Int
  chance                 Int
  or                     Int                @default(0)
  poidsMaxInventaire     Int                @default(2000)
  joueurId               Int
  joueur                 Joueur             @relation(fields: [joueurId], references: [id])
  raceId                 Int
  race                   Race               @relation(fields: [raceId], references: [id])
  mapId                  Int?
  positionX              Int                @default(0)
  positionY              Int                @default(0)
  map                    Map?               @relation("PersonnageMap", fields: [mapId], references: [id])
  groupes                GroupePersonnage[]
  groupesLeader          Groupe[]           @relation("GroupeLeader")
  equipements            Json               @default("{}")
  sortsAppris            PersonnageSort[]
  inventaireItems        InventaireItem[]
  inventaireRessources   InventaireRessource[]
  quetes                 QuetePersonnage[]
  combatsSolo            Combat[]           @relation("CombatSolo")
  donjonRunSolo          DonjonRun?         @relation("DonjonRunSolo")
}

model PersonnageSort {
  id           Int        @id @default(autoincrement())
  personnageId Int
  personnage   Personnage @relation(fields: [personnageId], references: [id], onDelete: Cascade)
  sortId       Int
  sort         Sort       @relation(fields: [sortId], references: [id])

  @@unique([personnageId, sortId])
}

model Groupe {
  id          Int                @id @default(autoincrement())
  nom         String
  joueurId    Int
  joueur      Joueur             @relation(fields: [joueurId], references: [id])
  leaderId    Int?
  leader      Personnage?        @relation("GroupeLeader", fields: [leaderId], references: [id])
  personnages GroupePersonnage[]
  donjonRun   DonjonRun?
}

model GroupePersonnage {
  groupeId     Int
  personnageId Int
  groupe       Groupe     @relation(fields: [groupeId], references: [id])
  personnage   Personnage @relation(fields: [personnageId], references: [id])

  @@id([groupeId, personnageId])
}

model Combat {
  id               Int               @id @default(autoincrement())
  status           CombatStatus      @default(EN_COURS)
  tourActuel       Int               @default(1)
  entiteActuelleId Int?
  grilleLargeur    Int
  grilleHauteur    Int
  groupeId         Int?
  personnageId     Int?
  personnage       Personnage?       @relation("CombatSolo", fields: [personnageId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  entites          CombatEntite[]
  effetsActifs     EffetActif[]
  cases            CombatCase[]
  cooldowns        SortCooldown[]
  logs             CombatLog[]
  zonesActives     ZonePoseeCombat[]
}

// Zone posée au sol : glyphe (visible, déclenche en début de tour) ou piège (invisible, déclenche au passage)
model ZonePoseeCombat {
  id             Int       @id @default(autoincrement())
  combatId       Int
  combat         Combat    @relation(fields: [combatId], references: [id], onDelete: Cascade)
  x              Int
  y              Int
  poseurId       Int       // CombatEntite qui a posé la zone
  poseurEquipe   Int       // pour la visibilité des pièges côté client
  estPiege       Boolean   @default(false)  // false = glyphe, true = piège
  toursRestants  Int       // tours restants avant expiration
  // Zone d'effet au déclenchement
  zoneTaille     Int       @default(0)
  zoneType       String    @default("CASE")
  // Dégâts pré-calculés (avec la stat du poseur au moment du cast)
  degatsMinFinal Int       @default(0)
  degatsMaxFinal Int       @default(0)
  statUtilisee   StatType  @default(FORCE)
  // Effet secondaire optionnel (poison, debuff PM, etc.)
  effetId        Int?
  effet          Effet?    @relation(fields: [effetId], references: [id])

  @@index([combatId])
  @@index([combatId, x, y])
}

model SortCooldown {
  id            Int    @id @default(autoincrement())
  combatId      Int
  combat        Combat @relation(fields: [combatId], references: [id], onDelete: Cascade)
  entiteId      Int
  sortId        Int
  sort          Sort   @relation(fields: [sortId], references: [id])
  toursRestants Int

  @@unique([combatId, entiteId, sortId])
}

model CombatCase {
  id                Int     @id @default(autoincrement())
  combatId          Int
  combat            Combat  @relation(fields: [combatId], references: [id], onDelete: Cascade)
  x                 Int
  y                 Int
  bloqueDeplacement Boolean @default(false)
  bloqueLigneDeVue  Boolean @default(false)

  @@unique([combatId, x, y])
}

model CombatEntite {
  id                  Int              @id @default(autoincrement())
  combatId            Int
  combat              Combat           @relation(fields: [combatId], references: [id])
  personnageId        Int?
  nom                 String
  equipe              Int
  positionX           Int
  positionY           Int
  initiative          Int
  ordreJeu            Int
  pvMax               Int
  pvActuels           Int
  paMax               Int
  paActuels           Int
  pmMax               Int
  pmActuels           Int
  force               Int
  intelligence        Int
  dexterite           Int
  agilite             Int
  vie                 Int
  chance              Int
  invocateurId        Int?
  invocateur          CombatEntite?    @relation("Invocations", fields: [invocateurId], references: [id])
  invocations         CombatEntite[]   @relation("Invocations")
  armeData            Json?
  armeCooldownRestant Int              @default(0)
  niveau              Int?
  monstreTemplateId   Int?
  monstreTemplate     MonstreTemplate? @relation(fields: [monstreTemplateId], references: [id])
  iaType              IAType?
  poBonus             Int              @default(0)
  bonusCritique       Int              @default(0)
  // Résistances snapshot (calculées au début du combat)
  resistanceForce          Int  @default(0)
  resistanceIntelligence   Int  @default(0)
  resistanceDexterite      Int  @default(0)
  resistanceAgilite        Int  @default(0)
  // Bonus dommages/soins snapshot
  bonusDommages            Int  @default(0)
  bonusSoins               Int  @default(0)
}

model EffetActif {
  id             Int    @id @default(autoincrement())
  combatId       Int
  combat         Combat @relation(fields: [combatId], references: [id], onDelete: Cascade)
  entiteId       Int
  effetId        Int
  effet          Effet  @relation(fields: [effetId], references: [id])
  toursRestants  Int
  lanceurId      Int?
  // Valeur pré-calculée au cast (ex: bouclier = random(min,max)*multiplicateur au lancer)
  valeurCourante Int?
}

model CombatLog {
  id        Int           @id @default(autoincrement())
  combatId  Int
  combat    Combat        @relation(fields: [combatId], references: [id], onDelete: Cascade)
  tour      Int
  message   String
  type      CombatLogType
  createdAt DateTime      @default(now())

  @@index([combatId])
}

// ==================== GRILLES DE COMBAT (liées aux Maps) ====================

model MapCase {
  id                Int     @id @default(autoincrement())
  mapId             Int
  map               Map     @relation(fields: [mapId], references: [id], onDelete: Cascade)
  x                 Int
  y                 Int
  bloqueDeplacement Boolean @default(false)
  bloqueLigneDeVue  Boolean @default(false)
  estExclue         Boolean @default(false)

  @@unique([mapId, x, y])
}

model MapSpawn {
  id     Int @id @default(autoincrement())
  mapId  Int
  map    Map @relation(fields: [mapId], references: [id], onDelete: Cascade)
  x      Int
  y      Int
  equipe Int // 0 = joueurs, 1 = ennemis
  ordre  Int // 1-8

  @@unique([mapId, equipe, ordre])
  @@unique([mapId, x, y])
}

// ==================== INVENTAIRE & ÉCONOMIE ====================

model InventaireItem {
  id              Int        @id @default(autoincrement())
  personnageId    Int
  personnage      Personnage @relation(fields: [personnageId], references: [id], onDelete: Cascade)
  equipementId    Int
  equipement      Equipement @relation(fields: [equipementId], references: [id])
  bonusForce      Int        @default(0)
  bonusIntelligence Int      @default(0)
  bonusDexterite  Int        @default(0)
  bonusAgilite    Int        @default(0)
  bonusVie        Int        @default(0)
  bonusChance     Int        @default(0)
  bonusPA         Int        @default(0)
  bonusPM         Int        @default(0)
  bonusPO         Int        @default(0)
  bonusCritique   Int        @default(0)
  // Résistances rollées (valeurs fixées au drop/craft)
  resistanceForce         Int  @default(0)
  resistanceIntelligence  Int  @default(0)
  resistanceDexterite     Int  @default(0)
  resistanceAgilite       Int  @default(0)
  // Bonus dommages et soins rollés
  bonusDommages           Int  @default(0)
  bonusSoins              Int  @default(0)
  estEquipe       Boolean    @default(false)
  createdAt       DateTime   @default(now())

  @@index([personnageId])
  @@index([personnageId, estEquipe])
}

model Ressource {
  id          Int                   @id @default(autoincrement())
  nom         String                @unique
  description String?
  poids       Int                   @default(1)
  estPremium  Boolean               @default(false)
  inventaires      InventaireRessource[]
  drops            MonstreDrop[]
  ingredients      RecetteIngredient[]
  marchandLignes   MarchandLigne[]
  queteRecompenses QueteRecompense[]
  queteEtapes      QueteEtape[]          @relation("QueteEtapeRessource")
}

model InventaireRessource {
  id           Int        @id @default(autoincrement())
  personnageId Int
  personnage   Personnage @relation(fields: [personnageId], references: [id], onDelete: Cascade)
  ressourceId  Int
  ressource    Ressource  @relation(fields: [ressourceId], references: [id])
  quantite     Int        @default(1)

  @@unique([personnageId, ressourceId])
}

model MonstreDrop {
  id            Int              @id @default(autoincrement())
  monstreId     Int
  monstre       MonstreTemplate  @relation(fields: [monstreId], references: [id], onDelete: Cascade)
  ressourceId   Int?
  ressource     Ressource?       @relation(fields: [ressourceId], references: [id])
  equipementId  Int?
  equipement    Equipement?      @relation(fields: [equipementId], references: [id])
  tauxDrop      Float            @default(0.3)
  quantiteMin   Int              @default(1)
  quantiteMax   Int              @default(1)

  @@index([monstreId])
}

model Recette {
  id            Int                @id @default(autoincrement())
  nom           String             @unique
  description   String?
  equipementId  Int
  equipement    Equipement         @relation(fields: [equipementId], references: [id])
  niveauMinimum Int                @default(1)
  coutOr        Int                @default(0)
  ingredients   RecetteIngredient[]
}

model RecetteIngredient {
  id          Int       @id @default(autoincrement())
  recetteId   Int
  recette     Recette   @relation(fields: [recetteId], references: [id], onDelete: Cascade)
  ressourceId Int
  ressource   Ressource @relation(fields: [ressourceId], references: [id])
  quantite    Int       @default(1)

  @@unique([recetteId, ressourceId])
}

model Panoplie {
  id          Int              @id @default(autoincrement())
  nom         String           @unique
  description String?
  equipements Equipement[]
  bonus       PanoplieBonus[]
}

model PanoplieBonus {
  id              Int      @id @default(autoincrement())
  panoplieId      Int
  panoplie        Panoplie @relation(fields: [panoplieId], references: [id], onDelete: Cascade)
  nombrePieces    Int
  bonusForce      Int      @default(0)
  bonusIntelligence Int    @default(0)
  bonusDexterite  Int      @default(0)
  bonusAgilite    Int      @default(0)
  bonusVie        Int      @default(0)
  bonusChance     Int      @default(0)
  bonusPA         Int      @default(0)
  bonusPM         Int      @default(0)
  bonusPO         Int      @default(0)
  bonusCritique   Int      @default(0)

  @@unique([panoplieId, nombrePieces])
}

// ==================== PNJ MARCHANDS ====================

enum DialogueType {
  ACCUEIL
  SANS_INTERACTION
}

model PNJ {
  id          Int             @id @default(autoincrement())
  nom         String
  description String?
  mapId       Int
  map         Map             @relation(fields: [mapId], references: [id])
  positionX   Int
  positionY   Int
  estMarchand Boolean         @default(true)
  lignes      MarchandLigne[]
  dialogues   PNJDialogue[]
  quetesDepart Quete[]         @relation("QuetePnjDepart")
  quetesEtapes QueteEtape[]   @relation("QueteEtapePnj")
}

model PNJDialogue {
  id         Int          @id @default(autoincrement())
  pnjId      Int
  pnj        PNJ          @relation(fields: [pnjId], references: [id], onDelete: Cascade)
  type       DialogueType
  texte      String
  ordre      Int          @default(0)
  queteId    Int?
  quete      Quete?       @relation(fields: [queteId], references: [id], onDelete: SetNull)
  etapeOrdre Int?

  @@index([pnjId])
}

model MarchandLigne {
  id           Int        @id @default(autoincrement())
  pnjId        Int
  pnj          PNJ        @relation(fields: [pnjId], references: [id], onDelete: Cascade)
  equipementId Int?
  equipement   Equipement? @relation(fields: [equipementId], references: [id])
  ressourceId  Int?
  ressource    Ressource?  @relation(fields: [ressourceId], references: [id])
  prixMarchand Int?
  prixRachat   Int?
}

// ==================== QUÊTES ====================

enum QueteEtapeType {
  PARLER_PNJ
  TUER_MONSTRE
  APPORTER_RESSOURCE
  APPORTER_EQUIPEMENT
}

enum QueteStatut {
  EN_COURS
  TERMINEE
}

model Quete {
  id           Int               @id @default(autoincrement())
  nom          String
  description  String?
  niveauRequis Int               @default(1)
  pnjDepartId  Int?
  pnjDepart    PNJ?              @relation("QuetePnjDepart", fields: [pnjDepartId], references: [id])
  etapes       QueteEtape[]
  recompenses  QueteRecompense[]
  personnages  QuetePersonnage[]
  prerequis    QueteRequis[]     @relation("QuetePrincipale")
  estPrerequis QueteRequis[]     @relation("QuetePrerequisite")
  pnjDialogues PNJDialogue[]
}

model QueteRequis {
  queteId     Int
  quete       Quete @relation("QuetePrincipale",   fields: [queteId],     references: [id], onDelete: Cascade)
  prerequisId Int
  prerequis   Quete @relation("QuetePrerequisite", fields: [prerequisId], references: [id])

  @@id([queteId, prerequisId])
}

model QueteEtape {
  id                Int              @id @default(autoincrement())
  queteId           Int
  quete             Quete            @relation(fields: [queteId], references: [id], onDelete: Cascade)
  ordre             Int
  description       String
  type              QueteEtapeType
  pnjId             Int?
  pnj               PNJ?            @relation("QueteEtapePnj", fields: [pnjId], references: [id])
  monstreTemplateId Int?
  monstreTemplate   MonstreTemplate? @relation(fields: [monstreTemplateId], references: [id])
  quantite          Int?
  ressourceId       Int?
  ressource         Ressource?       @relation("QueteEtapeRessource", fields: [ressourceId], references: [id])
  equipementId      Int?
  equipement        Equipement?      @relation("QueteEtapeEquipement", fields: [equipementId], references: [id])

  @@unique([queteId, ordre])
}

model QueteRecompense {
  id                Int         @id @default(autoincrement())
  queteId           Int
  quete             Quete       @relation(fields: [queteId], references: [id], onDelete: Cascade)
  xp                Int         @default(0)
  or                Int         @default(0)
  ressourceId       Int?
  ressource         Ressource?  @relation(fields: [ressourceId], references: [id])
  quantiteRessource Int?
  equipementId      Int?
  equipement        Equipement? @relation(fields: [equipementId], references: [id])
}

model QuetePersonnage {
  id            Int         @id @default(autoincrement())
  queteId       Int
  quete         Quete       @relation(fields: [queteId], references: [id])
  personnageId  Int
  personnage    Personnage  @relation(fields: [personnageId], references: [id])
  statut        QueteStatut @default(EN_COURS)
  etapeActuelle Int         @default(1)
  compteurEtape Int         @default(0)

  @@unique([queteId, personnageId])
}

// ==================== COMPÉTENCES PASSIVES ====================

model CompetencePassive {
  id                Int     @id @default(autoincrement())
  nom               String
  description       String?
  niveauDeblocage   Int
  bonusForce        Int     @default(0)
  bonusIntelligence Int     @default(0)
  bonusDexterite    Int     @default(0)
  bonusAgilite      Int     @default(0)
  bonusVie          Int     @default(0)
  bonusChance       Int     @default(0)
  bonusPa           Int     @default(0)
  bonusPm           Int     @default(0)
  bonusPo           Int     @default(0)
  bonusCritique     Int     @default(0)
  bonusDommages     Int     @default(0)
  bonusSoins        Int     @default(0)
}

// ==================== DONJONS ====================

model Donjon {
  id          Int              @id @default(autoincrement())
  nom         String
  description String?
  regionId    Int
  region      Region           @relation(fields: [regionId], references: [id])
  niveauMin   Int              @default(1)
  niveauMax   Int              @default(5)
  bossId      Int
  boss        MonstreTemplate  @relation(fields: [bossId], references: [id])
  salles      DonjonSalle[]
  runs        DonjonRun[]
  portails    MapConnection[]
}

model DonjonSalle {
  id           Int                      @id @default(autoincrement())
  donjonId     Int
  donjon       Donjon                   @relation(fields: [donjonId], references: [id], onDelete: Cascade)
  ordre        Int                      // 1, 2, 3, 4
  mapId        Int
  map          Map                      @relation(fields: [mapId], references: [id])
  compositions DonjonSalleComposition[]

  @@unique([donjonId, ordre])
  @@index([donjonId])
}

model DonjonSalleComposition {
  id                Int             @id @default(autoincrement())
  salleId           Int
  salle             DonjonSalle     @relation(fields: [salleId], references: [id], onDelete: Cascade)
  difficulte        Int             // 4, 6, ou 8
  monstreTemplateId Int
  monstre           MonstreTemplate @relation(fields: [monstreTemplateId], references: [id])
  niveau            Int
  quantite          Int             @default(1)

  @@index([salleId, difficulte])
}

model DonjonRun {
  id             Int        @id @default(autoincrement())
  donjonId       Int
  donjon         Donjon     @relation(fields: [donjonId], references: [id])
  groupeId       Int?       @unique  // Un seul run actif par groupe (null si solo)
  groupe         Groupe?    @relation(fields: [groupeId], references: [id])
  personnageId   Int?       @unique  // Un seul run actif par personnage solo (null si groupe)
  personnage     Personnage? @relation("DonjonRunSolo", fields: [personnageId], references: [id])
  salleActuelle  Int        @default(1)  // 1-4
  difficulte     Int        // 4, 6 ou 8 ennemis par salle
  termine        Boolean    @default(false)
  victoire       Boolean?   // null = en cours, true = gagné, false = perdu
  combatActuel   Int?       // ID du combat en cours (null si aucun)
  mapOrigineId   Int?       // Map d'où le joueur vient (pour y retourner)
  monstresCaches Json?      // Monstres pré-calculés avec boss boost pour la salle courante
  createdAt      DateTime   @default(now())

  @@index([groupeId])
  @@index([personnageId])
}
